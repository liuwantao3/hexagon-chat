# Application
DISABLE_VERCEL_ANALYTICS=false
PORT=3000
HOST=

# Database
DATABASE_URL=file:./HexagonChat.sqlite

# LangChain (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=hexagon-chat

# Redis (optional)
REDIS_HOST=

# API Keys (fill in as needed)
MOONSHOT_API_KEY=
GEMINI_API_KEY=
COHERE_API_KEY=
COHERE_MODEL=
COHERE_BASE_URL=

# Vector Database
# Supported values: chroma, milvus, qdrant
VECTOR_STORE=chroma
CHROMADB_URL=http://localhost:8000
MILVUS_URL=http://localhost:19530

# Administration
SUPER_ADMIN_NAME=

# Proxy (optional)
# ALL_PROXY=socks5://127.0.0.1:1080
# NUXT_MODEL_PROXY_URL=socks5://127.0.0.1:1080

# Security - REQUIRED for production
# Generate a secure secret: openssl rand -hex 32
SECRET=

# Chat settings
NUXT_PUBLIC_CHAT_MAX_ATTACHED_MESSAGES=50